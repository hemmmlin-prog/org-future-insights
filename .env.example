# 阿里云百炼 API Key 配置示例
# ----------------------------------------------------------------
# 真实 key 不放在工作区，存到用户家目录的标准位置：
#   ~/.config/org-future-insights/.env
# 并赋 600 权限确保只有你能读：
#   chmod 600 ~/.config/org-future-insights/.env
#
# 文件格式（在那个文件里写一行，不是这里）：
#   DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# 此 .env.example 只是占位说明，不含真实 key，可以安全进 git。
# ----------------------------------------------------------------

DASHSCOPE_API_KEY=sk-your-bailian-key-here
